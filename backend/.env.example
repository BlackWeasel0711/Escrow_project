PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/escrow"
JWT_SECRET="change-this-to-a-long-random-string"

# Comma-separated list of allowed web origins (e.g. https://app.example.com,http://localhost:3000).
# Leave empty in development to allow all origins.
CORS_ORIGINS=

# --- HTTPS / TLS ---
# Behind a TLS-terminating proxy (Render/Nginx/Cloudflare), set FORCE_HTTPS=true to
# redirect any plain-HTTP request to HTTPS. Leave unset/false for local dev.
FORCE_HTTPS=false
# To serve HTTPS directly (no proxy), point these at your PEM key/cert files.
TLS_KEY_PATH=
TLS_CERT_PATH=

# Optional email notifications. Without SMTP_URL, notifications are stored in-app only.
# Example: smtps://user:pass@smtp.example.com:465
SMTP_URL=
NOTIFY_FROM="SafePay Escrow <no-reply@safepay.local>"

# Leave true until you have real sandbox credentials for the gateways below.
# Deposits/releases/refunds return fake references instantly instead of calling the real APIs.
SIMULATE_PAYMENTS=true

# --- PayPal (sandbox) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# --- M-Pesa / Daraja (sandbox) ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_TEST_MSISDN=254708374149
MPESA_CALLBACK_URL=https://your-public-url/api/webhooks/mpesa
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# --- Visa via Stripe (sandbox/test mode) ---
STRIPE_SECRET_KEY=
